<NavButton>:
    markup: True
    background_normal: ""
    background_down: ""
    background_color: 0.157, 0.157, 0.157, 1  # background color
    color: 1, 1, 1, 1
    font_size: "16sp"

<PrimaryButton>:
    markup: True

    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0   # Disable default fill

    color: 0, 0, 0, 1
    disabled_color: 0.33, 0.33, 0.33, 1

    canvas.before:
        Color:
            rgba:
                (0.9, 0.9, 0.9, 1) if self.disabled else (1, 1, 1, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<ThemedPopup>:
    title: ""
    separator_height: 0

    title_size: 0.0001      # Effectively removes bar
    title_align: "center"

    background: ""
    background_color: 1, 1, 1, 0
    overlay_color: 0, 0, 0, 0

    canvas.before:
        Color:
            rgba: 0.157, 0.157, 0.157, 1   # #282828

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<HeaderLabel>:
    markup: True
    font_size: "32px"

<Root>:
    canvas.before:
        Color:
            rgba: 0.082, 0.082, 0.082, 1  # normalized #151515
        Rectangle:
            pos: self.pos
            size: self.size

    orientation: "vertical"
    BoxLayout:
        size_hint_y: None
        height: 60
        spacing: 10

    ScreenManager:
        id: sm

        Home:
            name: "home"
        Voice:
            name: "voice"
        Scanner:
            name: "scanner"

    BoxLayout:
        size_hint_y: None
        height: 60
        spacing: 10
        padding: 5

        canvas.before:
            Color:
                rgba: 0, 0, 0, 0.2
            RoundedRectangle:
                pos: self.x, self.y + 6
                size: self.width, self.height
                radius: [5]

            Color:
                rgba: 0, 0, 0, 0.15
            RoundedRectangle:
                pos: self.x, self.y + 4
                size: self.width, self.height
                radius: [5]

            Color:
                rgba: 0, 0, 0, 0.1
            RoundedRectangle:
                pos: self.x, self.y + 2
                size: self.width, self.height
                radius: [5]

            # Background rectangle
            Color:
                rgba: 0.157, 0.157, 0.157, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [5]


        NavButton:
            text: "Home"
            on_release: sm.current = "home"
        NavButton:
            text: "Voice"
            on_release: sm.current = "voice"
        NavButton:
            text: "Scanner"
            on_release: sm.current = "scanner"


<DocumentScanner>:
    orientation: 'vertical'

    HeaderLabel:
        text: "[b]Document Scanner[/b]"
        halign: "left"
        text_size: self.width - dp(16), self.height
        size_hint: (1, 0.2)

    Camera:
        id: camera
        resolution: (640, 480)
        play: False

    Label:
        id: loading_text
        opacity: 0
        text: "Loading..."

    BoxLayout:
        size_hint_y: None
        height: '48dp'
        anchor_x: 'center'
        anchor_y: 'center'
        spacing: 10

        PrimaryButton:
            id: scan_button
            text: '[b]Scan[/b]'
            size_hint_x: 0.25
            size_hint_y: None
            height: '48dp'
            on_press: root.capture()
            disabled: False

        PrimaryButton:
            id: upload_button
            text: '[b]Upload[/b]'
            size_hint_x: 0.25
            size_hint_y: None
            height: '48dp'
            on_press: root.upload()
            disabled: True


<Home>:
    HeaderLabel:
        text: "[b]Home Screen[/b]"

<Voice>:
    HeaderLabel:
        text: "[b]Voice Screen[/b]"

<Scanner>:
    DocumentScanner:
        id: cam_view
        padding: [0, 0, 0, 20]  # left, top, right, bottom: 20px gap
