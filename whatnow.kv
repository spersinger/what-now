<Root>:
    orientation: "vertical"
    BoxLayout:
        size_hint_y: None
        height: 60
        spacing: 10

        Button:
            text: "Settings"
            on_release: sm.current = "settings"

    ScreenManager:
        id: sm

        Home:
            name: "home"
        Voice:
            name: "voice"
        Scanner:
            name: "scanner"
        Edit:
            name: "edit"

    BoxLayout:
        size_hint_y: None
        height: 60
        spacing: 10

        Button:
            text: "Home"
            on_release: sm.current = "home"
        Button:
            text: "Voice"
            on_release: sm.current = "voice"
        Button:
            text: "Scanner"
            on_release: sm.current = "scanner"
        Button:
            text: "Edit Manually"
            on_release: sm.current = "edit"

<CameraClick>:
    orientation: 'vertical'
    Camera:
        id: camera
        resolution: (640, 480)
        play: False 
    BoxLayout:
        size_hint_y: None
        height: '48dp'
        anchor_x: 'center'
        anchor_y: 'center'

        Button:
            text: 'Scan'
            size_hint_x: 0.25
            size_hint_y: None
            height: '48dp'
            on_press: root.capture()

        Button:
            text: 'Upload'
            size_hint_x: 0.25
            size_hint_y: None
            height: '48dp'
            on_press: root.upload()

<Home>:
    Label:
        text: "Home Screen"

<Voice>:
    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        id: voice_root

        canvas.before:
            Color:
                rgba: 0, 0, 1, 0.5  # Blue background
            Rectangle:
                pos: self.pos
                size: self.size

        # Mic icon and text label in the center
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            BoxLayout:
                orientation: "vertical"
                spacing: 20
                #padding: [20,0]
                size_hint_x: 0.95
                size_hint_y: None
                size: self.minimum_size

                TextInput:
                    id: voice_text_input  #will be used to show voice input to user

                    hint_text: "Record to start!"
                    font_size: "16sp"
                    size_hint_x: 1

                    size_hint_y: None
                    height: "50dp"

                Image:
                    id: mic_icon
                    source: "mic_white.png"
                    size_hint: None, None
                    size: "96dp", "96dp"
                    pos_hint: {"center_x": 0.5}


        Button:
            id: record_button
            text: "Record"
            size_hint_y: None
            height: "48dp"
            on_release: root.start_voice()
        Button:
            id: submit_voice_button
            text: "Submit"
            disabled: True
            size_hint_y: None
            height: "48dp"
            on_release: root.submit_voice()




<Scanner>:
   # CameraClick:
    #    id: cam_view
     #   padding: [0, 0, 0, 20]  # left, top, right, bottom: 20px gap

<Edit>:
    Label:
        text: "Edit Screen"


