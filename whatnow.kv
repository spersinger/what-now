<Voice>:

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        id: voice_root

        HeaderLabel:
            text: "[b]Voice[/b]"
            halign: "left"
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None

        # Mic icon and text label in the center
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            BoxLayout:
                orientation: "vertical"
                spacing: 20
                size_hint_x: 0.95
                size_hint_y: None
                size: self.minimum_size

                BoxLayout:
                    id: voice_box_container
                    size_hint_x: 1
                    size_hint_y: None
                    height: "50dp"
                    padding: dp(1)
                    
                    canvas.before:
                        # Border
                        Color:
                            rgba: 0.325, 0.325, 0.325, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]

                        # Fill
                        Color:
                            rgba: 0.157, 0.157, 0.157, 1
                        RoundedRectangle:
                            pos: self.x + 1, self.y + 1
                            size: self.width - 2, self.height - 2
                            radius: [10]

                    VoiceTextInput:

                        id: voice_text_input  #will be used to show voice input to user

                        hint_text: "Record to start!"
                        font_size: "16sp"
                        size_hint_x: 1

                        size_hint_y: None
                        height: "50dp"

                Image:
                    id: mic_icon
                    source: "../mic_white.png"
                    size_hint: None, None
                    size: "96dp", "96dp"
                    pos_hint: {"center_x": 0.5}


        PrimaryButton:
            id: record_button
            text: "Record"
            size_hint_y: None
            height: "48dp"

            on_release: root.start_voice()
        PrimaryButton:
            id: submit_voice_button
            text: "Submit"
            disabled: True
            size_hint_y: None
            height: "48dp"

            on_release: root.submit_voice()

<Scanner>:
    DocumentScanner:
        id: cam_view
        padding: [0, 0, 0, 20]  # left, top, right, bottom: 20px gap
