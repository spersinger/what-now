<NavButton>:
    markup: True
    background_normal: ""
    background_down: ""
    background_color: 0.157, 0.157, 0.157, 1  # background color

    color: (0.4, 0.4, 0.4, 1) if self.state == "down" else (1, 1, 1, 1)
    font_size: "16sp"

<ThemedBox>:
    background_normal: ""
    background_active: ""
    background_color: 1, 1, 1, 0

    canvas.before:
        # Border
        Color:
            rgba: 0.325, 0.325, 0.325, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

        # Fill
        Color:
            rgba: 0.157, 0.157, 0.157, 1
        RoundedRectangle:
            pos: self.x + 1, self.y + 1
            size: self.width - 2, self.height - 2
            radius: [10]

<VoiceTextInput>:
    background_normal: ""
    background_active: ""
    background_color: 1, 1, 1, 0

    foreground_color: 1, 1, 1, 1
    disabled_foreground_color: 1, 1, 1, 1
    cursor_color: 1, 1, 1, 1
    selection_color: 0.3, 0.3, 0.3, 0.5

    padding: dp(12), dp(10)
    multiline: True
    line_height: 1

<PrimaryButton>:
    markup: True

    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0   # Disable default fill

    color: 0, 0, 0, 1
    disabled_color: 0.33, 0.33, 0.33, 1
    #background_normal: ""
            #background_down: ""
            #background_color:
                #(0.78, 0.36, 0.14, 1) if self.state == 'down' else (0.06, 0.12, 0.30, 1)

    canvas.before:
        Color:
            rgba:
                (0.9, 0.9, 0.9, 1) if self.disabled else (0.7, 0.7, 0.7, 1) if self.state == 'down' else (1, 1, 1, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<ThemedPopup>:
    title: ""
    separator_height: 0

    title_size: 0.0001      # Effectively removes bar
    title_align: "center"

    background: ""
    background_color: 1, 1, 1, 0
    overlay_color: 0, 0, 0, 0

    canvas.before:
        Color:
            rgba: 0.157, 0.157, 0.157, 1   # #282828

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<HeaderLabel>:
    markup: True
    font_size: "32px"

<Root>:
    canvas.before:
        Color:
            rgba: 0.082, 0.082, 0.082, 1  # normalized #151515
        Rectangle:
            pos: self.pos
            size: self.size

    orientation: "vertical"
    BoxLayout:
        size_hint_y: None
        height: 60
        spacing: 10

    ScreenManager:
        id: sm

        Home:
            name: "home"
        Voice:
            name: "voice"
        Scanner:
            name: "scanner"

    BoxLayout:
        size_hint_y: None
        height: 60
        spacing: 10

        canvas.before:
            Color:
                rgba: 0.325, 0.325, 0.325, 1
            Rectangle:
                pos: self.x - 1, self.y - 1
                size: self.width + 2, self.height + 2

            Color:
                rgba: 0.157, 0.157, 0.157, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [5]


        NavButton:
            id: home_button
            text: "[b]Home[/b]"
            screen_name: "home"
            on_release:
                app.root.set_active("home")
        NavButton:
            id: voice_button
            text: "Voice"
            screen_name: "voice"
            # Set initial non active color
            color: 0.6, 0.6, 0.6, 1
            on_release:
                app.root.set_active("voice")
        NavButton:
            id: scanner_button
            text: "Scanner"
            screen_name: "scanner"
            # Set initial non active color
            color: 0.6, 0.6, 0.6, 1
            on_release:
                app.root.set_active("scanner")


<DocumentScanner>:
    orientation: 'vertical'

    HeaderLabel:
        text: "[b]Document Scanner[/b]"
        halign: "left"
        text_size: self.width - dp(16), self.height
        size_hint: (1, 0.2)

    Camera:
        id: camera
        resolution: (640, 480)
        play: False

    Label:
        id: loading_text
        opacity: 0
        text: "Loading..."

    BoxLayout:
        size_hint_y: None
        orientation: "vertical"
        height: '48dp'
        anchor_x: 'center'
        anchor_y: 'center'
        spacing: 10
        padding: 10

        PrimaryButton:
            id: scan_button
            text: '[b]Scan[/b]'
            size_hint_x: 1
            size_hint_y: None
            height: '48dp'
            on_press: root.capture()
            disabled: False

        PrimaryButton:
            id: upload_button
            text: '[b]Upload[/b]'
            size_hint_x: 1
            size_hint_y: None
            height: '48dp'
            on_press: root.upload()
            disabled: False


<Home>:
    ScrollView:
        do_scroll_x: False
        do_scroll_y: True

        id: home_root

        BoxLayout:
            orientation: "vertical"
            padding: 10
            spacing: 10
            size_hint_y: None  # Don't let it shrink to fit ScrollView

            height: self.minimum_height  # Expand to fit all children


            HeaderLabel:
                id: calendar_month_label
                text: "[b]February[/b]"
                halign: "left"
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None

            # Calendar Box
            ThemedBox:
                orientation: "vertical"
                padding: 10
                spacing: 10
                
                size_hint_y: None  # Don't let it shrink to fit ScrollView

                height: self.minimum_height  # Expand to fit all children

            HeaderLabel:
                text: "[b]Upcoming Events[/b]"
                halign: "left"
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None

            # Upcoming events box
            ThemedBox:
                orientation: "vertical"
                padding: 10
                spacing: 10
                
                size_hint_y: None  # Don't let it shrink to fit ScrollView

                height: self.minimum_height  # Expand to fit all children

                # Test Box of upcoming Events
                BoxLayout:
                    orientation: "vertical"
                    padding: 10
                    spacing: 4
                    size_hint_y: None  # Don't let it shrink to fit ScrollView

                    height: self.minimum_height  # Expand to fit all children


                    Label:
