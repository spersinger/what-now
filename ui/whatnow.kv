<Root>:
    orientation: "horizontal" if self.width >= 800 else "vertical"
    BoxLayout:
        id: nav_bar
        orientation: "horizontal" if root.width < 800 else "vertical"
        size_hint_x: None if root.width >= 800 else 1
        size_hint_y: None if root.width < 800 else 1
        width: 120 if root.width >= 800 else 0
        height: 60 if root.width < 800 else 0
        spacing: 10
        padding: [0, 10] if root.width >= 800 else [10, 0]
        canvas.before:
            Color:
                rgba: 0.325, 0.325, 0.325, 1
            Rectangle:
                pos: self.x - 1, self.y - 1
                size: self.width + 2, self.height + 2
            Color:
                rgba: 0.157, 0.157, 0.157, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [5]
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "top"
            size_hint_y: 1 if root.width >= 800 else None
            size_hint_x: None if root.width >= 800 else 1
            width: 120 if root.width >= 800 else 0
            height: 60 if root.width < 800 else 0
            BoxLayout:
                orientation: "vertical" if root.width >= 800 else "horizontal"
                size_hint: (1, None) if root.width >= 800 else (None, 1)
                height: 150 if root.width >= 800 else 0  # 3 buttons * 50

                width: 0 if root.width >= 800 else 360   # expand horizontally on mobile

                spacing: 0 
                NavButton:
                    id: home_button
                    text: "[b]Home[/b]"
                    screen_name: "home"
                    size_hint_y: None if root.width >= 800 else 1
                    height: 50 if root.width >= 800 else 0
                    on_release: root.set_active(self.screen_name)
                NavButton:
                    id: voice_button
                    text: "Voice"
                    screen_name: "voice"
                    color: 0.6, 0.6, 0.6, 1
                    size_hint_y: None if root.width >= 800 else 1
                    height: 50 if root.width >= 800 else 0
                    on_release: root.set_active(self.screen_name)
                NavButton:
                    id: scanner_button
                    text: "Scanner"
                    screen_name: "scanner"
                    color: 0.6, 0.6, 0.6, 1
                    size_hint_y: None if root.width >= 800 else 1
                    height: 50 if root.width >= 800 else 0
                    on_release: root.set_active(self.screen_name)
    ScreenManager:
        id: sm
        size_hint_x: 1
        size_hint_y: 1
        Home:
            name: "home"
        Voice:
            name: "voice"
        Scanner:
            name: "scanner"

