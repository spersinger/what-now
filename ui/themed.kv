<NavButton>:
    markup: True
    background_normal: ""
    background_down: ""
    background_color: 0.157, 0.157, 0.157, 1  # background color

    color: (0.4, 0.4, 0.4, 1) if self.state == "down" else (1, 1, 1, 1)
    font_size: "16sp"

<ThemedSpinner>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0, 0, 0, 1
    canvas.before:
        Color:
            rgba: (0.302, 0.659, 0.910, 1) if self.state == 'down' else (0.9, 0.9, 0.9, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

    canvas.after:
        Color:
            rgba: (0.302, 0.659, 0.910, 1)
        Triangle:
            points:
                [ self.right - 20, self.y + self.height * 0.55, self.right - 8,  self.y + self.height * 0.55, self.right - 14, self.y + self.height * 0.35 ]

<ThemedCheckBox>:
    background_checkbox_normal: ''
    background_checkbox_down: ''
    background_radio_normal: ''
    background_radio_down: ''
    color: 0, 0, 0, 0
    canvas.before:
        # Outer white rounded rectangle
        Color:
            rgba: (1, 1, 1, 1)
        RoundedRectangle:
            pos: self.center_x - self.height / 2, self.center_y - self.height / 2
            size: self.height, self.height
            radius: [6]
        # Blue inner rounded rectangle (only when checked)
        Color:
            rgba: (0.302, 0.659, 0.910, 1) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.center_x - self.height / 2, self.center_y - self.height / 2
            size: self.height, self.height
            radius: [6]

<ThemedSpinnerOption>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0, 0, 0, 1
    canvas.before:
        Color:
            rgba: (0.302, 0.659, 0.910, 1) if self.state == 'down' else (0.9, 0.9, 0.9, 1)
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: (0.8, 0.8, 0.8, 1)
        Line:
            points: self.x, self.y, self.right, self.y
            width: 2

<ThemedBox>:
    background_normal: ""
    background_active: ""
    background_color: 1, 1, 1, 0

    canvas.before:
        # Border
        Color:
            rgba: 0.325, 0.325, 0.325, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

        # Fill
        Color:
            rgba: 0.157, 0.157, 0.157, 1
        RoundedRectangle:
            pos: self.x + 1, self.y + 1
            size: self.width - 2, self.height - 2
            radius: [10]

<VoiceTextInput>:
    background_normal: ""
    background_active: ""
    background_color: 1, 1, 1, 0

    foreground_color: 1, 1, 1, 1
    disabled_foreground_color: 1, 1, 1, 1
    cursor_color: 1, 1, 1, 1
    selection_color: 0.3, 0.3, 0.3, 0.5

    padding: dp(12), dp(10)
    multiline: True
    line_height: 1

<ThemedToggleButton>:
    markup: True
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    disabled_color: 0.33, 0.33, 0.33, 1
    canvas.before:
        Color:
            rgba: (0.302, 0.659, 0.910, 1) if self.state == 'down' else (0.9, 0.9, 0.9, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<PrimaryButton>:
    markup: True

    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0   # Disable default fill

    color: 0, 0, 0, 1
    disabled_color: 0.33, 0.33, 0.33, 1
    #background_normal: ""
            #background_down: ""
            #background_color:
                #(0.78, 0.36, 0.14, 1) if self.state == 'down' else (0.06, 0.12, 0.30, 1)

    canvas.before:
        Color:
            rgba:
                (0.9, 0.9, 0.9, 1) if self.disabled else (0.7, 0.7, 0.7, 1) if self.state == 'down' else (1, 1, 1, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<ThemedPopup>:
    title: ""
    separator_height: 0

    title_size: 0.0001      # Effectively removes bar
    title_align: "center"

    background: ""
    background_color: 1, 1, 1, 0
    overlay_color: 0, 0, 0, 0

    canvas.before:
        Color:
            rgba: 0.157, 0.157, 0.157, 1   # #282828

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [5]

<HeaderLabel>:
    markup: True
    font_size: "32px"

<CalendarDayCell>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height
    spacing: 2
    padding: 2
    Label:
        text: root.day_text
        font_size: "12sp"
        halign: "center"
        size_hint_y: None
        height: 24
        color: root.day_color
    BoxLayout:
        id: event_bars
        orientation: "vertical"
        size_hint_y: None
        height: self.minimum_height
        spacing: 4

<CalendarDayToday>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height
    spacing: 2
    padding: 2

    # Blue circle for today
    Label:
        text: root.day_text
        font_size: "12sp"
        bold: True
        halign: "center"
        size_hint_y: None
        height: 24
        canvas.before:
            Color:
                rgba: 0.302, 0.659, 0.910, 1
            Ellipse:
                pos: self.x + self.width/2 - 12, self.y
                size: 24, 24
    BoxLayout:
        id: event_bars
        orientation: "vertical"
        size_hint_y: None
        height: self.minimum_height
        spacing: 4

<EventItem>:
    orientation: "vertical"
    padding: [4, 6]
    spacing: 2
    size_hint_y: None
    height: self.minimum_height

    Label:
        text: "[b]" + root.event_type + "[/b]"
        markup: True
        halign: "left"
        font_size: "14sp"
        size_hint_y: None
        height: self.texture_size[1]
        text_size: self.width, None

    Label:
        text: root.event_name
        halign: "left"
        font_size: "12sp"
        size_hint_y: None
        height: self.texture_size[1]
        text_size: self.width, None
    Label:
        text: root.event_date
        halign: "left"
        font_size: "11sp"
        color: 0.541, 0.541, 0.541, 1
        size_hint_y: None
        height: self.texture_size[1]
        text_size: self.width, None

    Label:
        text: root.event_time
        halign: "left"
        font_size: "11sp"
        color: 0.541, 0.541, 0.541, 1
        size_hint_y: None
        height: self.texture_size[1]
        text_size: self.width, None

<EditEventItem>:
    orientation: "horizontal"
    padding: [4, 6]
    spacing: 2
    size_hint_y: None
    height: self.minimum_height

    BoxLayout:
        id: event_details 
        orientation: "vertical"
        size_hint_y: None
        height: self.minimum_height
        spacing: 4

        Label:
            text: "[b]" + root.event_type + "[/b]"
            markup: True
            halign: "left"
            font_size: "14sp"
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None

        Label:
            text: root.event_name
            halign: "left"
            font_size: "12sp"
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None
        Label:
            text: root.event_date
            halign: "left"
            font_size: "11sp"
            color: 0.541, 0.541, 0.541, 1
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None

        Label:
            text: root.event_time
            halign: "left"
            font_size: "11sp"
            color: 0.541, 0.541, 0.541, 1
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None

    PrimaryButton:
        id: edit_button
        size_hint_y: 0.75
        size_hint_x: 0.15
        text: "Edit"
