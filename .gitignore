# whitelist-style gitignore

# ignore everything
*
# !/* (uncomment if you want to always include a specific kind of file regardless of where it is)

# except:
# -------

# the gitignore (a little important)
!.gitignore

# project documents
!LICENSE
!README.md

# other misc. project files
!requirements.txt
!setup.sh
!whatnow.kv

# source files
!src/*.py
