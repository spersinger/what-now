# whitelist-style gitignore

# ignored items:

# (default: everything, but still search folders)
*
!*/







# allowed items:

# the gitignore (a little important)
!.gitignore

# project documents
!LICENSE
!README.md

# other misc. project files
!requirements.txt
!setup.sh
!whatnow.kv

# source files
!src/*.py
!ui/*.kv
